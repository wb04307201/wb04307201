/.idea/

# Maven build artifacts
**/target/

# Claude settings (用户/机器级，不应 commit)
/.claude/settings.local.json

# Skill 镜像（由 setup.sh / pre-commit hook 从 skills/ 自动同步，不应 commit）
/.claude/skills/
/.codex/skills/

# Python 缓存（脚本运行时产生的临时 .pyc，不应 commit）
__pycache__/
*.pyc
*.pyo

# note-health skill 临时目录（体检扫描输出，不应 commit）
note/.health-tmp/

# Obsidian 工作区配置（个人/机器级，不应 commit）
note/.obsidian/
