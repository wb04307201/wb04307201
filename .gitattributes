# 统一仓库文本文件行尾为 LF（避免 Windows CRLF 噪声）
# 详见 CLAUDE.md "Mistake 8.5: Windows 行尾污染"
* text=auto eol=lf

# 显式标注常见文本文件（防止某些工具误判为二进制）
*.md   text eol=lf
*.js   text eol=lf
*.py   text eol=lf
*.sh   text eol=lf
*.txt  text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.toml text eol=lf

# 二进制保持原样（避免 git 误转换）
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
*.ico  binary
*.woff binary
*.woff2 binary